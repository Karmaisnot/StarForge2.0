# StarForge console — server / API configuration.
# Copy to `.env` (or `.env.local`) and fill in once the backend is ready.
#
# Today (no .env present) the app runs against the built-in mock server, which
# serves the same REST contract the real API will expose — so flipping to the
# live backend is a config change, not a code change.

# Browser-facing base URL. Leave empty when the console and API share a tenant
# origin (production) or when using the local Vite proxy below. An absolute URL
# is only suitable when the backend explicitly allows this console origin via CORS.
VITE_API_URL=

# Development only: Vite proxies /api/* to this HTTPS tenant host. It is not
# used by the production build.
VITE_API_PROXY_TARGET=https://starforge.78.111.91.113.nip.io

# Data source switch. "true" (default) = built-in mock server.
# Set to "false" tomorrow to hit VITE_API_URL for real.
VITE_USE_MOCK=true

# Optional development-only opaque session key from POST /api/v1/auth/login/.
# Prefer Settings → Backend connection: it stores the runtime session key in
# this browser. Do not set real credentials here: VITE_* values are visible to
# every user of the production bundle.
VITE_API_TOKEN=

# Simulated latency (ms) for the mock server, so loading states behave like a
# real network. Ignored once VITE_USE_MOCK=false.
VITE_MOCK_LATENCY=140
