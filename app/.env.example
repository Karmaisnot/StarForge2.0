# StarForge console — server / API configuration.
# Copy to `.env` (or `.env.local`) and fill in once the backend is ready.
#
# Today (no .env present) the app runs against the built-in mock server, which
# serves the same REST contract the real API will expose — so flipping to the
# live backend is a config change, not a code change.

# Base URL of the real API. Leave empty to call the same origin ("/students").
# Example: https://api.starforge.uz/v1
VITE_API_URL=

# Data source switch. "true" (default) = built-in mock server.
# Set to "false" tomorrow to hit VITE_API_URL for real.
VITE_USE_MOCK=true

# Optional static bearer token. At runtime a token in localStorage
# ("sf-auth-token") takes precedence over this value.
VITE_API_TOKEN=

# Simulated latency (ms) for the mock server, so loading states behave like a
# real network. Ignored once VITE_USE_MOCK=false.
VITE_MOCK_LATENCY=140
